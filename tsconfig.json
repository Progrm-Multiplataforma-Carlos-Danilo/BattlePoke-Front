{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "module": "ESNext",
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@homeIntegrations/*": [
        "./src/features/home/integration/*"
      ],
      "@pokedexIntegrations/*": [
        "./src/features/pokedex/integration/*"
      ],
      "@sharedTypes/*": [
        "./src/shared/types/*"
      ],
      "@sharedApi/*": [
        "./src/shared/api/*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx"
  ]

}
