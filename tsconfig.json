{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "module": "ESNext",
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@homeTypes/*": [
        "./src/features/home/@types/*"
      ],
      "@homeIntegrations/*": [
        "./src/features/home/integration/*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx"
  ]

}
